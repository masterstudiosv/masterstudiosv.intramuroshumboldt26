Options -Indexes

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Bloquear acceso directo a la carpeta /js/ desde el navegador
  RewriteRule ^js/.*$ - [F,L,NC]

  # Bloquear acceso directo al script GAS
  RewriteRule ^Code\.gs$ - [F,L,NC]
</IfModule>

# Seguridad adicional: no permitir ejecución de .gs en servidor
<Files "*.gs">
  Order Allow,Deny
  Deny from all
</Files>

# Headers de seguridad
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-XSS-Protection "1; mode=block"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
